# モックモード用の環境変数
# `npm run dev:mock` で使用される

# MSWによるモックを有効化
USE_MOCKS=true

# Cloudflare Worker API設定（MSWがインターセプトするためダミー値でOK）
CLOUDFLARE_WORKER_API_URL=http://mock-worker.local
CLOUDFLARE_WORKER_API_TOKEN=mock-worker-token

